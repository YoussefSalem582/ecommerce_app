# Copy to `.env` at repo root to override defaults from assets/env/default.env.
# Never commit `.env` — it is gitignored.

BASE_URL=https://fakestoreapi.com

# Stripe Payment Sheet (optional — leave empty for demo checkout)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
# Create via Stripe CLI or your backend API:
# STRIPE_PAYMENT_INTENT_CLIENT_SECRET=pi_xxx_secret_xxx

# demo = in-memory fakes (no HTTP); live = Fake Store HTTP
APP_ENV=demo
